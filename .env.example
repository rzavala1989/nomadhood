# PostgreSQL connection string (Neon, Supabase, Railway, etc.)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# GitHub OAuth app credentials (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth app credentials (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Auth.js v5 secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# Base URL of your app (defaults to http://localhost:3000)
NEXTAUTH_URL=http://localhost:3000

# MapTiler API key for interactive map tiles (optional, free tier: https://cloud.maptiler.com/)
# Falls back to CartoDB Positron tiles if not set
NEXT_PUBLIC_MAPTILER_KEY=

# Admin email — user with this email gets auto-promoted to admin (optional)
ADMIN_EMAIL=
