# PostgreSQL connection string (Neon, Supabase, Railway, etc.)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# GitHub OAuth app credentials (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Auth.js v5 secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# Resend API key for email magic links (https://resend.com)
RESEND_API_KEY=

# Base URL of your app
NEXTAUTH_URL=http://localhost:3000
