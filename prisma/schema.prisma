generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique @db.VarChar(255)
  name          String?   @db.VarChar(100)
  image         String?   @db.VarChar(500)
  isAdmin       Boolean   @default(false)
  emailVerified DateTime?
  password      String?   @db.VarChar(255)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  reviews         Review[]
  favorites       Favorite[]
  recommendations RecommendationCache[]
  newsAlerts      NewsAlert[]

  @@index([email])
  @@index([isAdmin])
}

model Neighborhood {
  id             String          @id @default(uuid())
  name           String          @db.VarChar(100)
  city           String          @db.VarChar(50)
  state          String          @db.Char(2)
  zip            String          @db.VarChar(10)
  description    String?         @db.Text
  latitude       Float?
  longitude      Float?
  boundary       Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  reviews        Review[]
  favorites      Favorite[]
  walkScoreCache WalkScoreCache?
  imageCache     NeighborhoodImageCache[]
  recommendations RecommendationCache[]
  snapshots      NeighborhoodSnapshot[]
  news           NeighborhoodNews[]
  newsAlerts     NewsAlert[]

  @@index([city, state])
  @@index([zip])
  @@index([latitude, longitude])
}

model Review {
  id             String       @id @default(uuid())
  rating         Int          @db.SmallInt
  comment        String?      @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  userId         String
  neighborhoodId String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  neighborhood   Neighborhood @relation(fields: [neighborhoodId], references: [id], onDelete: Cascade)
  dimensions     ReviewDimension[]

  @@index([neighborhoodId])
  @@index([userId])
  @@index([rating])
  @@unique([userId, neighborhoodId])
}

model ReviewDimension {
  id         String   @id @default(uuid())
  reviewId   String
  review     Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  dimension  String   @db.VarChar(30)
  rating     Int      @db.SmallInt

  @@unique([reviewId, dimension])
  @@index([reviewId])
  @@index([dimension])
}

model Favorite {
  id             String       @id @default(uuid())
  position       Int          @default(0)
  createdAt      DateTime     @default(now())
  userId         String
  neighborhoodId String
  user           User         @relation(fields: [userId], references: [id])
  neighborhood   Neighborhood @relation(fields: [neighborhoodId], references: [id])

  @@unique([userId, neighborhoodId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- External API Cache Models ---

model WalkScoreCache {
  id             String       @id @default(uuid())
  neighborhoodId String       @unique
  neighborhood   Neighborhood @relation(fields: [neighborhoodId], references: [id], onDelete: Cascade)
  walkScore      Int?
  transitScore   Int?
  bikeScore      Int?
  walkDescription    String?  @db.VarChar(100)
  transitDescription String?  @db.VarChar(100)
  bikeDescription    String?  @db.VarChar(100)
  rawResponse    Json
  fetchedAt      DateTime     @default(now())
  expiresAt      DateTime

  @@index([expiresAt])
}

model RentcastCache {
  id               String   @id @default(uuid())
  zip              String   @unique @db.VarChar(10)
  medianRent       Float?
  medianRentSqft   Float?
  medianSalePrice  Float?
  medianSaleSqft   Float?
  rawResponse      Json
  fetchedAt        DateTime @default(now())
  expiresAt        DateTime

  @@index([expiresAt])
}

model CrimeDataCache {
  id                  String   @id @default(uuid())
  city                String   @db.VarChar(100)
  state               String   @db.Char(2)
  oriCode             String?  @db.VarChar(20)
  violentCrimeRate    Float?
  propertyCrimeRate   Float?
  population          Int?
  dataYear            Int?
  dataQuality         String   @default("unavailable") @db.VarChar(20)
  rawResponse         Json
  fetchedAt           DateTime @default(now())
  expiresAt           DateTime

  @@unique([city, state])
  @@index([expiresAt])
}

model BlsDataCache {
  id         String   @id @default(uuid())
  seriesId   String   @unique @db.VarChar(30)
  city       String   @db.VarChar(100)
  state      String   @db.Char(2)
  seriesType String   @db.VarChar(20)
  value      Float?
  period     String?  @db.VarChar(10)
  year       Int?
  rawResponse Json
  fetchedAt  DateTime @default(now())
  expiresAt  DateTime

  @@index([city, state])
  @@index([seriesType])
  @@index([expiresAt])
}

model EventbriteCache {
  id                 String   @id @default(uuid())
  city               String   @db.VarChar(100)
  state              String   @db.Char(2)
  upcomingEventCount Int      @default(0)
  events             Json     @default("[]")
  rawResponse        Json
  fetchedAt          DateTime @default(now())
  expiresAt          DateTime

  @@unique([city, state])
  @@index([expiresAt])
}

model NeighborhoodImageCache {
  id               String       @id @default(uuid())
  neighborhoodId   String
  neighborhood     Neighborhood @relation(fields: [neighborhoodId], references: [id], onDelete: Cascade)
  position         Int          @default(0)
  source           String       @db.VarChar(20)
  imageUrl         String
  thumbUrl         String?
  altText          String?
  photographerName String?
  photographerUrl  String?
  pageUrl          String?
  unsplashDownloadUrl String?
  rawResponse      Json
  fetchedAt        DateTime     @default(now())
  expiresAt        DateTime

  @@unique([neighborhoodId, imageUrl])
  @@index([neighborhoodId])
  @@index([expiresAt])
}

model ApiRateLimitTracker {
  id           String   @id @default(uuid())
  apiName      String   @unique @db.VarChar(50)
  callCount    Int      @default(0)
  periodStart  DateTime @default(now())
  periodEnd    DateTime
  lastCalledAt DateTime?
}

model RecommendationCache {
  id               String       @id @default(uuid())
  userId           String
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  neighborhoodId   String
  neighborhood     Neighborhood @relation(fields: [neighborhoodId], references: [id], onDelete: Cascade)
  matchScore       Float
  matchReasons     Json
  computedAt       DateTime     @default(now())

  @@unique([userId, neighborhoodId])
  @@index([userId, matchScore])
  @@index([computedAt])
}

model NeighborhoodSnapshot {
  id                String       @id @default(uuid())
  neighborhoodId    String
  neighborhood      Neighborhood @relation(fields: [neighborhoodId], references: [id], onDelete: Cascade)
  snapshotDate      DateTime     @db.Date
  nomadScore        Int
  avgRating         Float?
  reviewCount       Int
  favoriteCount     Int
  dimensionAvgs     Json?

  @@unique([neighborhoodId, snapshotDate])
  @@index([neighborhoodId, snapshotDate])
  @@index([snapshotDate])
}

model NeighborhoodNews {
  id               String       @id @default(cuid())
  neighborhoodId   String
  neighborhood     Neighborhood @relation(fields: [neighborhoodId], references: [id], onDelete: Cascade)
  articleId        String       @unique
  title            String
  description      String?      @db.Text
  url              String
  sourceId         String?
  sentiment        String?      @db.VarChar(20)
  category         String[]
  aiTag            String[]
  pubDate          DateTime
  fetchedAt        DateTime     @default(now())

  @@index([neighborhoodId, pubDate(sort: Desc)])
}

model NewsAlert {
  id                String       @id @default(cuid())
  userId            String
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  neighborhoodId    String
  neighborhood      Neighborhood @relation(fields: [neighborhoodId], references: [id], onDelete: Cascade)
  triggerArticleIds String[]
  alertType         String       @db.VarChar(30)
  title             String
  summary           String?      @db.Text
  severity          String       @db.VarChar(10)
  isRead            Boolean      @default(false)
  triggerDate       DateTime     @db.Date
  createdAt         DateTime     @default(now())

  @@unique([userId, neighborhoodId, alertType, triggerDate])
  @@index([userId, isRead])
  @@index([userId, createdAt(sort: Desc)])
  @@index([neighborhoodId])
}
